# API URL — set this as a Vercel environment variable in production
# e.g. https://your-backend.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:4000

# Google OAuth: console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0
# Add http://localhost:3000 as Authorized JavaScript origin
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Reddit OAuth: reddit.com/prefs/apps → create app (type: "installed app")
# Redirect URI: http://localhost:3000/auth/reddit-callback
NEXT_PUBLIC_REDDIT_CLIENT_ID=your-reddit-client-id
